rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function ownUserDoc() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function ownProfileExists() {
      return exists(ownUserDoc());
    }

    function getOwnProfile() {
      return get(ownUserDoc()).data;
    }

    // Never call get(...).data unless the document exists — otherwise rule evaluation fails
    // (seen as permission-denied on getDoc for new users when paired with isAdmin()).
    function isAdmin() {
      return isAuthenticated() &&
        ownProfileExists() &&
        getOwnProfile().get('role', 'restricted') in ['admin', 'superadmin'];
    }

    function isActive() {
      let profile = getOwnProfile();
      let status = profile.get('status', {
        'isActive': false,
        'isBlocked': true
      });
      return isAuthenticated() &&
        ownProfileExists() &&
        status.get('isActive', false) == true &&
        status.get('isBlocked', true) == false;
    }

    function isVerified() {
      return isAuthenticated() && request.auth.token.email_verified == true;
    }

    function withinLimits() {
      let profile = getOwnProfile();
      let role = profile.get('role', 'restricted');
      let limits = profile.get('limits', {});
      let usage = profile.get('usage', {});

      return role in ['admin', 'superadmin'] || (
        usage.get('fileCount', 0) <= limits.get('maxFiles', 100) &&
        usage.get('storageUsedMB', 0) <= limits.get('storageMB', 10)
      );
    }

    function chatRoomPath(roomId) {
      return /databases/$(database)/documents/chat_rooms/$(roomId);
    }

    function chatRoomExists(roomId) {
      return exists(chatRoomPath(roomId));
    }

    function isChatRoomMember(roomId) {
      return isAuthenticated() &&
        ownProfileExists() &&
        isActive() &&
        isVerified() &&
        chatRoomExists(roomId) &&
        (
          get(chatRoomPath(roomId)).data.get('createdByUid', '') == request.auth.uid ||
          get(chatRoomPath(roomId)).data.get('memberEmails', []).hasAny([request.auth.token.email])
        );
    }

    function isReactionOnlyMessageUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'reactions',
        'updatedAt'
      ]);
    }

    function hasModuleAccess(document) {
      let perms = getOwnProfile().get('permissions', {});
      let modules = perms.get('modules', {});

      return
        (document == 'studyos_courses' && (modules.get('courses', false) == true || perms.get('courses', false) == true)) ||
        (document == 'studyos_videos' && (modules.get('videos', false) == true || perms.get('videos', false) == true)) ||
        (document == 'studyos_notes' && (modules.get('notes', false) == true || perms.get('notes', false) == true)) ||
        (document == 'studyos_resources' && (modules.get('resources', false) == true || perms.get('resources', false) == true)) ||
        (document == 'studyos_projects' && (modules.get('projects', false) == true || perms.get('projects', false) == true)) ||
        (document == 'studyos_tasks' && (modules.get('projects', false) == true || perms.get('projects', false) == true)) ||
        (document == 'studyos_workspace' && (modules.get('workspace', false) == true || perms.get('workspace', false) == true)) ||
        (document == 'studyos_analytics' && (modules.get('analytics', false) == true || perms.get('analytics', false) == true)) ||
        (document == 'studyos_reminders' && (modules.get('reminders', false) == true || perms.get('reminders', false) == true)) ||
        (document == 'studyos_goals') ||
        (document == 'studyos_folders') ||
        (document == 'studyos_weekly_planner') ||
        (document == 'studyos_review_prefs') ||
        (document == 'studyos_assignments' && (
          modules.get('projects', false) == true || perms.get('projects', false) == true ||
          modules.get('courses', false) == true || perms.get('courses', false) == true
        )) ||
        (document == 'studyos_papers' && (modules.get('resources', false) == true || perms.get('resources', false) == true)) ||
        (document == 'google_calendar_token') ||
        (document == 'google_calendar_sync_enabled') ||
        (document == 'active_workspace_project') ||
        (document == 'active_workspace_context') ||
        (document == 'studyos_settings') ||
        (document == 'studyos_streak') ||
        (document == 'studyos_notifications') ||
        (document == 'studyos_personalization') ||
        (document == 'studyos_study_prefs') ||
        (document == 'studyos_notif_settings') ||
        (document == 'studyos_privacy') ||
        (document == 'studyos_achievements');
    }

    function isCreatingOwnProfile(userId) {
      return isOwner(userId) &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.role in ['user', 'restricted'];
    }

    function isSafeSelfProfileUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'name',
        'avatar',
        'bio',
        'university',
        'degree',
        'year',
        'phone',
        'lastLogin',
        'updatedAt'
      ]);
    }

    match /users/{userId} {
      // Short-circuit: own uid first so we never touch admin get() for normal users / new profiles.
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        (ownProfileExists() && getOwnProfile().get('role', 'restricted') in ['admin', 'superadmin'])
      );
      allow create: if isCreatingOwnProfile(userId);
      allow update: if (isOwner(userId) && isSafeSelfProfileUpdate()) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // Read: owner may load their own synced blobs; module gates apply on writes only.
    match /users/{userId}/data/{document} {
      allow read: if (isOwner(userId) && isActive()) || isAdmin();
      allow write: if (isOwner(userId) && isActive() && isVerified() && hasModuleAccess(document) && withinLimits()) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /settings/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /chat_rooms/{roomId} {
      allow read: if isChatRoomMember(roomId) || isAdmin();
      allow create: if isAuthenticated() &&
        ownProfileExists() &&
        isActive() &&
        isVerified() &&
        request.resource.data.createdByUid == request.auth.uid &&
        request.resource.data.createdByEmail == request.auth.token.email &&
        request.resource.data.memberEmails is list &&
        request.resource.data.memberEmails.hasAny([request.auth.token.email]) &&
        request.resource.data.title is string;
      allow update: if isChatRoomMember(roomId) || isAdmin();
      allow delete: if isChatRoomMember(roomId) || isAdmin();

      match /messages/{messageId} {
        allow read: if isChatRoomMember(roomId) || isAdmin();
        allow create: if isChatRoomMember(roomId) &&
          request.resource.data.senderUid == request.auth.uid &&
          request.resource.data.senderEmail == request.auth.token.email &&
          request.resource.data.text is string;
        allow update: if (
          isChatRoomMember(roomId) &&
          (
            resource.data.senderUid == request.auth.uid ||
            isReactionOnlyMessageUpdate()
          )
        ) || isAdmin();
        allow delete: if (
          isChatRoomMember(roomId) &&
          resource.data.senderUid == request.auth.uid
        ) || isAdmin();
      }
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }
  }
}
